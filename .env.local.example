# Copy to .env.local (and add the same vars in Vercel → Project → Settings → Environment Variables).
# When these are set, SimpleTeam uses Supabase (real auth + realtime, multi-user).
# When they're absent, it runs the local-storage demo automatically.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
